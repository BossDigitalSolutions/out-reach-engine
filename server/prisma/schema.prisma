generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  password            String
  name                String?
  role                UserRole   @default(MEMBER)
  twoFactorEnabled    Boolean    @default(false)
  twoFactorSecret     String?
  backupCodes         String?    // JSON array of bcrypt-hashed codes
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  settings         Settings?
  leads            Lead[]
  templates        EmailTemplate[]
  demoLinks        DemoLink[]
  emails           Email[]
  notes            Note[]
  revenue          RevenueEntry[]
  whatsAppMessages WhatsAppMessage[]
  sessions         Session[]
  activityLogs     ActivityLog[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Settings {
  id                String  @id @default(cuid())
  userId            String  @unique
  googleApiKey      String?
  anthropicApiKey   String?
  sendgridApiKey    String?
  senderName        String?
  senderEmail       String?
  emailSignature    String?
  dailySendLimit    Int     @default(30)
  unsubscribeUrl    String?
  warmupMode        Boolean @default(false)
  warmupDay         Int     @default(1)
  followupsEnabled  Boolean @default(true)
  followupInterval1 Int     @default(3)
  followupInterval2 Int     @default(5)
  followupInterval3 Int     @default(7)
  industryWeights   Json?
  whatsAppPhoneId   String?
  whatsAppToken     String?
  ghlApiKey         String?
  ghlLocationId     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id               String     @id @default(cuid())
  userId           String
  businessName     String
  ownerName        String?
  email            String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  industry         String?
  websiteUrl       String?
  hasWebsite       Boolean    @default(false)
  googleRating     Float?
  reviewCount      Int?
  description      String?
  status           LeadStatus @default(NEW)
  score            Int?
  followupsEnabled Boolean    @default(true)
  customDemoLink   String?
  placeId          String?
  ghlContactId     String?
  ownerTitle       String?
  linkedinUrl      String?
  websiteData      Json?
  websiteScore     Int?
  unsubscribed     Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails           Email[]
  notes            Note[]
  revenue          RevenueEntry[]
  whatsAppMessages WhatsAppMessage[]
}

enum LeadStatus {
  NEW
  CONTACTED
  OPENED
  REPLIED
  CALL_BOOKED
  CONVERTED
  LOST
}

model EmailTemplate {
  id            String   @id @default(cuid())
  userId        String
  name          String
  industry      String?
  subject       String
  body          String
  tone          String   @default("professional")
  seriesId      String?
  sequenceOrder Int      @default(1)
  delayDays     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrebuiltTemplate {
  id            String   @id @default(cuid())
  industry      String
  seriesId      String
  seriesName    String
  sequenceOrder Int      @default(1)
  delayDays     Int      @default(0)
  subject       String
  body          String
  tone          String   @default("professional")
  createdAt     DateTime @default(now())
}

model DemoLink {
  id        String   @id @default(cuid())
  userId    String
  industry  String
  url       String
  label     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Email {
  id               String      @id @default(cuid())
  userId           String
  leadId           String
  subject          String
  body             String
  status           EmailStatus @default(DRAFT)
  followupNumber   Int         @default(0)
  scheduledAt      DateTime?
  sentAt           DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  repliedAt        DateTime?
  bouncedAt        DateTime?
  messageId        String?
  unsubscribeToken String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

enum EmailStatus {
  DRAFT
  SCHEDULED
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  leadId    String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model RevenueEntry {
  id          String   @id @default(cuid())
  userId      String
  leadId      String?
  amount      Float
  description String?
  date        DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  userId      String
  leadId      String
  phone       String
  message     String
  status      String   @default("SENT")
  waMessageId String?
  sentAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
