# ============================================
# OutreachEngine Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ---- Database ----
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/outreachengine"

# ---- Server ----
PORT=3001
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Server public URL (used for unsubscribe links in emails)
SERVER_URL=http://localhost:3001

# ---- Auth ----
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ---- API Keys (can also be set per-user in the Settings page) ----
# Google Places API Key
# Get it at: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Maps JavaScript API
GOOGLE_PLACES_API_KEY=

# Anthropic Claude API Key
# Get it at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# SendGrid API Key
# Get it at: https://app.sendgrid.com/settings/api_keys
# Required permission: Mail Send (Full Access)
SENDGRID_API_KEY=
